# ============================
# Global ignores (OS / IDE)
# ============================
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
*.swo

# IntelliJ / VSCode
.idea/
.vscode/
*.iml

# ============================
# Java / Spring Boot (apps/api)
# ============================
apps/api/target/
apps/api/.classpath
apps/api/.project
apps/api/.settings/
apps/api/.idea/
apps/api/*.jar
# Maven / Gradle
apps/api/build/
apps/api/bin/
bin/
.factorypath
.project
.settings/
.classpath
.attach_*
.m2/

# ============================
# Node / React (apps/web)
# ============================
apps/web/node_modules/
apps/web/dist/
apps/web/.vite/
apps/web/.cache/
apps/web/npm-debug.log
apps/web/yarn-error.log

# Playwright test artifacts (generated)
apps/web/playwright-report/
apps/web/test-results/

# ============================
# Python / FastAPI
# ============================
stock-system-marketdata/app/__pycache__/
stock-system-marketdata/app/*.pyc
stock-system-marketdata/app/.venv/
stock-system-marketdata/app/venv/
stock-system-marketdata/app/.pytest_cache/
stock-system-marketdata/app/.mypy_cache/
stock-system-marketdata/function.zip
stock-system-marketdata/.env

# ============================
# Docker
# ============================
**/.dockerignore
**/Dockerfile~

# ============================
# Environment files
# ============================
*.env
*.env.local
*.env.development
*.env.production
infra/env/dev/*.env
infra/env/test/*.env
infra/env/prod/*.env

# ============================
# Terraform
# ============================
*.tfstate
*.tfstate.backup
*.exe
*.tfvars
.terraform/

# ============================
# ============================
# AI tools (generated/cache)
# ============================
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v4/
opencode.json
.codex

# Note: The following AI config files ARE tracked (do not ignore):
# .cursorrules
# .github/copilot-instructions.md
# .agents/workflows/
# AGENTS.md
# docs/STYLE_GUIDE.md
