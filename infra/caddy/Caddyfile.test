{
    admin off
    auto_https off

    servers {
        trusted_proxies static private_ranges
    }
}

http://{$CADDY_SITE_ADDRESS::80} {
    encode zstd gzip

    reverse_proxy {$API_UPSTREAM:api:8080} {
        health_uri /actuator/health
        health_interval 30s
        health_timeout 5s
    }

    header {
        -Server
    }

    log {
        output stdout
        format json
    }
}
